APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pos_bengkel_local
DB_USERNAME=pos_bengkel
DB_PASSWORD=pos_bengkel_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=app-id
REVERB_APP_KEY=app-key
REVERB_APP_SECRET=app-secret
REVERB_HOST=localhost
REVERB_BROADCAST_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

WHATSAPP_ENABLED=false
WHATSAPP_GO_DASHBOARD_URL=http://127.0.0.1:3000
WHATSAPP_API_BASE_URL=http://127.0.0.1:3000
WHATSAPP_API_TIMEOUT_SECONDS=15
WHATSAPP_API_RETRY_TIMES=2
WHATSAPP_API_RETRY_SLEEP_MS=250
WHATSAPP_API_USERNAME=
WHATSAPP_API_PASSWORD=
WHATSAPP_DEVICE_ID=

WHATSAPP_WEBHOOK_SECRET=secret
WHATSAPP_WEBHOOK_VERIFY_SIGNATURE=true
WHATSAPP_WEBHOOK_USE_GO=false
WHATSAPP_HEALTHCHECK_USE_GO=false

GO_BACKEND_BASE_URL=http://127.0.0.1:8081
GO_BACKEND_TIMEOUT_SECONDS=5
GO_SYNC_ENABLED=false
GO_SYNC_SHARED_TOKEN=change-me-sync-token
GO_SYNC_RETENTION_DAYS=30
GO_SYNC_RETENTION_PURGE_ENABLED=true
GO_SYNC_RETENTION_PURGE_DAILY_AT=03:20
GO_SYNC_RUN_TIMEOUT_SECONDS=60
GO_SYNC_RETRY_TIMEOUT_SECONDS=60
GO_SYNC_ALERT_TIMEOUT_SECONDS=30
GO_SYNC_RECONCILIATION_TIMEOUT_SECONDS=45
GO_SYNC_RETRY_DEFAULT_LIMIT=5
GO_SYNC_RETRY_MAX_LIMIT=200
GO_SYNC_SCHEDULE_ENABLED=false
GO_SYNC_SCHEDULE_DAILY_AT=23:40
GO_SYNC_SCHEDULE_RETRY_LIMIT=5
GO_SYNC_ALERT_ENABLED=false
GO_SYNC_ALERT_FAILED_MINUTES=120
GO_SYNC_ALERT_LIMIT=20
GO_SYNC_RECONCILIATION_ENABLED=false
GO_SYNC_RECONCILIATION_DAILY_AT=00:15
GO_SYNC_RECONCILIATION_MAX_VARIANCE=5

WHATSAPP_QUEUE=default
WHATSAPP_NOTIFY_SERVICE_ORDER_CREATED=true
WHATSAPP_NOTIFY_SERVICE_ORDER_UPDATED=false
