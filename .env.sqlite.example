# ============================================================================
# GO Backend Configuration - Choose ONE database driver below
# ============================================================================

# Option 1: SQLite (Local-First, Offline-Capable) - RECOMMENDED FOR WORKSHOPS
GO_DATABASE_DRIVER=sqlite
GO_DATABASE_SQLITE_PATH=./data/posbengkel.db

# Option 2: MySQL (Shared, Online Integration) - Uncomment to use
# GO_DATABASE_DRIVER=mysql
# GO_DATABASE_HOST=127.0.0.1
# GO_DATABASE_PORT=3306
# GO_DATABASE_NAME=laravel12_pos_bengkel
# GO_DATABASE_USER=root
# GO_DATABASE_PASSWORD=root

# ============================================================================
# GO Backend Server Configuration
# ============================================================================

GO_PORT=8081
GO_HOST=127.0.0.1
GO_ENVIRONMENT=local
GO_DEBUG=true
GO_LOG_LEVEL=info

# ============================================================================
# AUTHENTICATION & AUTHORIZATION (Critical)
# ============================================================================

# JWT Configuration
JWT_SECRET=change-this-in-production-minimum-32-characters
JWT_ISSUER=pos-bengkel-go
JWT_AUDIENCE=pos-bengkel-frontend
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# WebSocket Token (for realtime updates)
GO_WS_TOKEN=change-this-ws-token-in-production

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# CORS Configuration (for React Frontend)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With

# Password Security
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=1
PASSWORD_REQUIRE_NUMBERS=1
PASSWORD_REQUIRE_SYMBOLS=0

# Rate Limiting (brute force protection)
RATE_LIMIT_ENABLED=1
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW=300
RATE_LIMIT_API_REQUESTS=100
RATE_LIMIT_API_WINDOW=60

# Session/Token Settings
SESSION_TIMEOUT=86400
TOKEN_REFRESH_BEFORE_EXPIRY=3600

# API Authentication
API_KEY_ENABLED=0
API_KEY_HEADER_NAME=X-API-Key

# ============================================================================
# WebSocket / Real-time Communication
# ============================================================================

WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=8081
WEBSOCKET_PATH=/ws
WEBSOCKET_READ_BUFF_SIZE=4096
WEBSOCKET_WRITE_BUFF_SIZE=4096

# ============================================================================
# Data Sync (If using hybrid MySQL + SQLite)
# ============================================================================

GO_SYNC_ENABLED=false
GO_SYNC_INTERVAL=3600
GO_SYNC_TIMEOUT=30s
GO_SYNC_HOST_URL=http://127.0.0.1:8000
GO_SYNC_SHARED_TOKEN=change-me-sync-token
GO_SYNC_SOURCE_ID=local-workshop

# ============================================================================
# File Storage
# ============================================================================

STORAGE_PATH=./storage
MAX_FILE_SIZE=10485760

# ============================================================================
# Feature Flags
# ============================================================================

FEATURE_OFFLINE_MODE=true
FEATURE_REALTIME_UPDATES=true
FEATURE_INVENTORY_MANAGEMENT=true
FEATURE_PARTS_CATALOG=true
FEATURE_CUSTOMER_MANAGEMENT=true
FEATURE_APPOINTMENT_SCHEDULING=true
FEATURE_WARRANTY_MANAGEMENT=true
FEATURE_VOUCHER_MANAGEMENT=true
FEATURE_MULTI_LOCATION=true

# ============================================================================
# Notifications
# ============================================================================

NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_PUSHBULLET_ENABLED=false

# ============================================================================
# WhatsApp Integration (Optional)
# ============================================================================

WHATSAPP_GO_DASHBOARD_URL=
WHATSAPP_API_USERNAME=
WHATSAPP_API_PASSWORD=
WHATSAPP_WEBHOOK_SECRET=secret
WHATSAPP_WEBHOOK_VERIFY_SIGNATURE=true

# ============================================================================
# Development Tools
# ============================================================================

PROFILING_ENABLED=false
REQUEST_LOGGING=true
QUERY_LOGGING=false
